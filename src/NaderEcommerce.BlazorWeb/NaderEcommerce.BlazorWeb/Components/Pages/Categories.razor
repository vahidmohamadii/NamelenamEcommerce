@page "/categories"
@inject CatalogApiClient CatalogApi
@inject NavigationManager Navigation

<PageTitle>@SeoDefaults.PageTitle("دسته‌بندی لوازم آرایشی نفس")</PageTitle>
<HeadContent>
    <meta name="description" content="دسته‌بندی محصولات فروشگاه نفس برای پیدا کردن سریع لوازم آرایشی نفس، مراقبت پوست، عطر و ابزار زیبایی." />
    <meta property="og:title" content="دسته‌بندی‌های فروشگاه نفس" />
    <meta property="og:description" content="محصولات فروشگاه نفس را از مسیر دسته‌بندی‌های اصلی دنبال کن." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@CanonicalUrl" />
    <link rel="canonical" href="@CanonicalUrl" />
</HeadContent>

<section class="catalog-header">
    <p class="eyebrow">مسیرهای خرید فروشگاه نفس</p>
    <h1>دسته‌بندی‌ها</h1>
    <p>محصولات آرایشی و بهداشتی نفس را از مسیر دسته‌های اصلی دنبال کن.</p>
</section>

<section class="content-band">
    @if (isLoading)
    {
        <div class="loading-line">در حال دریافت دسته‌بندی‌ها...</div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="notice">@errorMessage</div>
    }
    else
    {
        <div class="category-grid">
            @foreach (var category in categories)
            {
                <a class="category-card" href="@($"/products?categorySlug={category.Slug}")">
                    <span>@category.ProductCount محصول</span>
                    <strong>@category.Name</strong>
                    <p>@category.Description</p>
                </a>
            }
        </div>
    }
</section>

@code {
    private IReadOnlyList<CategoryDto> categories = Array.Empty<CategoryDto>();
    private bool isLoading = true;
    private string? errorMessage;
    private string CanonicalUrl => Navigation.ToAbsoluteUri("categories").ToString();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            categories = await CatalogApi.GetCategoriesAsync();
        }
        catch (HttpRequestException)
        {
            errorMessage = "API کاتالوگ در دسترس نیست. پروژه WebApi را هم اجرا کن.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
