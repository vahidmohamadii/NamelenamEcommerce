@page "/admin/products"
@rendermode InteractiveServer
@inject AdminApiClient AdminApi
@inject StorefrontSessionService Session
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment

<PageTitle>مدیریت محصولات | فروشگاه نفس</PageTitle>
<NoIndexHead />

<section class="admin-shell">
    <header class="admin-header">
        <div>
            <p class="eyebrow">پنل مدیریت</p>
            <h1>محصولات</h1>
        </div>
        <nav class="admin-tabs">
            <NavLink href="admin">داشبورد</NavLink>
            <NavLink href="admin/products">محصولات</NavLink>
            <NavLink href="admin/categories">دسته‌بندی‌ها</NavLink>
            <NavLink href="admin/orders">سفارش‌ها</NavLink>
            <NavLink href="admin/coupons">کوپن‌ها</NavLink>
            <NavLink href="admin/cms">محتوا</NavLink>
            <NavLink href="admin/people">کاربران</NavLink>
        </nav>
    </header>

    <div class="admin-grid admin-grid--wide admin-products-grid">
        <section class="admin-card admin-product-editor">
            <h2>@(editingId is null ? "محصول جدید" : "ویرایش محصول")</h2>
            <form class="admin-form admin-product-form" @onsubmit="SaveAsync" @onsubmit:preventDefault>
                <div class="admin-product-form__top">
                    <section class="admin-product-panel admin-product-panel--info">
                        <h3>اطلاعات محصول</h3>
                        <div class="admin-product-fields">
                            <label>نام <input @bind="form.Name" /></label>
                            <label>اسلاگ <input @bind="form.Slug" /></label>
                            <label>SKU <input @bind="form.Sku" /></label>
                            <label class="admin-product-fields__wide">توضیحات <textarea @bind="form.Description"></textarea></label>
                            <label class="admin-product-fields__wide">مشخصات <textarea @bind="form.Specifications"></textarea></label>
                            <div class="admin-form__columns">
                                <label>قیمت <input type="number" step="1000" @bind="form.Price" /></label>
                                <label>تخفیف <input type="number" step="1000" @bind="form.DiscountPrice" /></label>
                                <label>موجودی <input type="number" @bind="form.Stock" /></label>
                            </div>
                        </div>
                    </section>

                    <section class="admin-option-list admin-product-panel admin-product-panel--categories">
                        <h3>دسته‌بندی‌ها</h3>
                        @foreach (var category in categories)
                        {
                            <label class="check-row">
                                <input type="checkbox" checked="@form.CategoryIds.Contains(category.Id)" @onchange="eventArgs => ToggleCategory(category.Id, eventArgs.Value)" />
                                @category.Name
                            </label>
                        }
                    </section>

                    <section class="admin-image-list admin-image-list--compact admin-product-panel admin-product-panel--images">
                    <div class="section-heading">
                        <h2>تصاویر</h2>
                        <button class="button button--ghost" type="button" @onclick="AddImage">افزودن تصویر</button>
                    </div>
                    @for (var index = 0; index < form.Images.Count; index++)
                    {
                        var image = form.Images[index];
                        <div class="admin-image-row">
                            <div class="admin-image-row__preview">
                                @if (!string.IsNullOrWhiteSpace(image.Url))
                                {
                                    <img src="@image.Url" alt="پیش‌نمایش تصویر محصول" />
                                }
                                else
                                {
                                    <span>بدون تصویر</span>
                                }
                            </div>
                            <div class="admin-image-row__fields">
                                <label>
                                    آپلود تصویر
                                    <InputFile class="admin-file-input" OnChange="args => UploadImageAsync(image, args)" accept="image/png,image/jpeg,image/webp,image/gif" />
                                </label>
                                <label>ترتیب <input type="number" @bind="image.DisplayOrder" /></label>
                            </div>
                            <div class="admin-image-row__actions">
                                <label class="check-row"><input type="checkbox" @bind="image.IsPrimary" /> تصویر اصلی</label>
                                <button class="button button--ghost" type="button" @onclick="() => RemoveImage(image)">حذف</button>
                            </div>
                        </div>
                    }
                    </section>
                </div>

                <div class="admin-checks">
                    <label class="check-row"><input type="checkbox" @bind="form.IsActive" /> فعال</label>
                    <label class="check-row"><input type="checkbox" @bind="form.IsFeatured" /> شاخص</label>
                    <label class="check-row"><input type="checkbox" @bind="form.IsBestSeller" /> پرفروش</label>
                </div>
                <div class="admin-actions">
                    <button class="button button--primary" type="submit">ذخیره</button>
                    <button class="button button--ghost" type="button" @onclick="ResetForm">جدید</button>
                </div>
            </form>
            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="notice">@message</div>
            }
        </section>

        <section class="admin-card admin-product-list">
            <h2>فهرست محصولات</h2>
            <div class="admin-table">
                @foreach (var product in products)
                {
                    <div class="admin-table__row admin-table__row--dense">
                        <span>@product.Name</span>
                        <span>@product.Sku</span>
                        <span>@product.Stock موجود</span>
                        <strong>@product.Price.ToString("N0")</strong>
                        <div class="admin-product-list__actions">
                            <button class="button button--ghost" type="button" @onclick="() => Edit(product)">ویرایش</button>
                            <button class="button button--ghost" type="button" @onclick="() => DeactivateAsync(product)">غیرفعال</button>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
</section>

@code {
    private IReadOnlyList<AdminProductDto> products = Array.Empty<AdminProductDto>();
    private IReadOnlyList<AdminCategoryDto> categories = Array.Empty<AdminCategoryDto>();
    private ProductForm form = new();
    private Guid? editingId;
    private string? message;
    private const long MaxImageUploadSize = 5 * 1024 * 1024;
    private static readonly Dictionary<string, string> AllowedImageExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ["image/jpeg"] = ".jpg",
        ["image/png"] = ".png",
        ["image/webp"] = ".webp",
        ["image/gif"] = ".gif"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        await Session.EnsureInitializedAsync();
        categories = await AdminApi.GetCategoriesAsync();
        products = await AdminApi.GetProductsAsync();
        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        message = null;
        try
        {
            var imageRequests = form.Images
                .Where(image => !string.IsNullOrWhiteSpace(image.Url))
                .Select(image => new UpsertProductImageRequest(
                    image.Url,
                    image.AltText,
                    image.DisplayOrder,
                    image.IsPrimary))
                .ToArray();

            var request = new UpsertProductRequest(
                form.Name,
                form.Slug,
                form.Sku,
                form.Description,
                form.Specifications,
                form.Price,
                form.DiscountPrice,
                form.Stock,
                form.IsActive,
                form.IsFeatured,
                form.IsBestSeller,
                null,
                form.CategoryIds.ToArray(),
                imageRequests);

            var saved = await AdminApi.SaveProductAsync(editingId, request);
            UpsertProductInList(saved);
            ResetForm();
        }
        catch (Exception exception) when (exception is StorefrontApiException or FormatException)
        {
            message = exception.Message;
        }
    }

    private void Edit(AdminProductDto product)
    {
        editingId = product.Id;
        form = new ProductForm
        {
            Name = product.Name,
            Slug = product.Slug,
            Sku = product.Sku,
            Description = product.Description,
            Specifications = product.Specifications,
            Price = product.Price,
            DiscountPrice = product.DiscountPrice,
            Stock = product.Stock,
            IsActive = product.IsActive,
            IsFeatured = product.IsFeatured,
            IsBestSeller = product.IsBestSeller,
            CategoryIds = product.CategoryIds.ToHashSet(),
            Images = product.Images
                .OrderBy(image => image.DisplayOrder)
                .Select(image => new ProductImageForm
                {
                    Url = image.Url,
                    AltText = image.AltText,
                    DisplayOrder = image.DisplayOrder,
                    IsPrimary = image.IsPrimary
                })
                .DefaultIfEmpty(new ProductImageForm { DisplayOrder = 1, IsPrimary = true })
                .ToList()
        };
    }

    private async Task DeactivateAsync(AdminProductDto product)
    {
        message = null;
        try
        {
            await AdminApi.SetProductActiveAsync(product.Id, new SetProductActiveRequest(false));
            products = products
                .Where(item => item.Id != product.Id)
                .ToArray();

            if (editingId == product.Id)
            {
                ResetForm();
            }
        }
        catch (StorefrontApiException exception)
        {
            message = exception.Message;
        }
    }

    private void UpsertProductInList(AdminProductDto product)
    {
        var currentProducts = products
            .Where(item => item.Id != product.Id)
            .ToList();

        if (product.IsActive)
        {
            currentProducts.Insert(0, product);
        }

        products = currentProducts
            .OrderByDescending(item => item.CreatedAt)
            .ToArray();
    }

    private void ResetForm()
    {
        editingId = null;
        form = new ProductForm();
    }

    private void ToggleCategory(Guid categoryId, object? value)
    {
        if (value is true)
        {
            form.CategoryIds.Add(categoryId);
        }
        else
        {
            form.CategoryIds.Remove(categoryId);
        }
    }

    private void AddImage()
    {
        if (form.Images.Count >= 10)
        {
            message = "هر محصول حداکثر می‌تواند ۱۰ تصویر داشته باشد.";
            return;
        }

        form.Images.Add(new ProductImageForm
        {
            DisplayOrder = form.Images.Count + 1,
            IsPrimary = form.Images.Count == 0
        });
    }

    private void RemoveImage(ProductImageForm image)
    {
        form.Images.Remove(image);
        if (form.Images.Count > 0 && form.Images.All(item => !item.IsPrimary))
        {
            form.Images[0].IsPrimary = true;
        }
    }

    private async Task UploadImageAsync(ProductImageForm image, InputFileChangeEventArgs args)
    {
        message = null;
        var file = args.File;

        if (!AllowedImageExtensions.TryGetValue(file.ContentType, out var extension))
        {
            message = "فرمت تصویر باید JPG، PNG، WEBP یا GIF باشد.";
            return;
        }

        if (file.Size > MaxImageUploadSize)
        {
            message = "حجم تصویر نباید بیشتر از ۵ مگابایت باشد.";
            return;
        }

        var uploadsDirectory = System.IO.Path.Combine(
            WebHostEnvironment.WebRootPath,
            "images",
            "uploads",
            "products");
        System.IO.Directory.CreateDirectory(uploadsDirectory);

        var fileName = $"{Guid.NewGuid():N}{extension}";
        var absolutePath = System.IO.Path.Combine(uploadsDirectory, fileName);

        await using var stream = System.IO.File.Create(absolutePath);
        await file.OpenReadStream(MaxImageUploadSize).CopyToAsync(stream);

        image.Url = $"/images/uploads/products/{fileName}";
        image.AltText = string.IsNullOrWhiteSpace(image.AltText) ? form.Name : image.AltText;
    }

    private sealed class ProductForm
    {
        public string Name { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string Sku { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Specifications { get; set; }
        public decimal Price { get; set; }
        public decimal? DiscountPrice { get; set; }
        public int Stock { get; set; }
        public bool IsActive { get; set; } = true;
        public bool IsFeatured { get; set; }
        public bool IsBestSeller { get; set; }
        public HashSet<Guid> CategoryIds { get; set; } = new();
        public List<ProductImageForm> Images { get; set; } = new()
        {
            new ProductImageForm { DisplayOrder = 1, IsPrimary = true }
        };
    }

    private sealed class ProductImageForm
    {
        public string Url { get; set; } = string.Empty;
        public string? AltText { get; set; }
        public int DisplayOrder { get; set; }
        public bool IsPrimary { get; set; }
    }
}
