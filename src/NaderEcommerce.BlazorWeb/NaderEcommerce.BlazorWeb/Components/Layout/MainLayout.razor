@inherits LayoutComponentBase

<div class="page" dir="rtl">
    <header class="site-header">
        <NavMenu />
    </header>

    <main class="site-main">
        @Body
    </main>

    <footer class="site-footer" aria-label="اطلاعات فروشگاه">
        <div class="site-footer__inner">
            <section class="site-footer__brand" aria-label="فروشگاه نفس">
                <a class="site-footer__logo-link" href="">
                    <img src="/images/brand/nafas-shop-logo.png" alt="لوگوی فروشگاه نفس" width="1254" height="1254" />
                    <span>فروشگاه نفس</span>
                </a>
                <p>خرید محصولات آرایشی و بهداشتی با پشتیبانی مستقیم فروشگاه.</p>
            </section>

            <section class="site-footer__contact" aria-label="اطلاعات تماس">
                <h2>تماس با ما</h2>
                <a class="site-footer__phone" href="tel:09031428163">09031428163</a>
            </section>

            <section class="site-footer__social" aria-label="شبکه‌های اجتماعی">
                <h2>شبکه‌های اجتماعی</h2>
                <div class="site-footer__social-links">
                    <a class="site-footer__social-link site-footer__social-link--instagram"
                       href="https://www.instagram.com/nafas_shop786?igsh=bzBlNGY0Yjl2MmNy"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="اینستاگرام فروشگاه نفس">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <defs>
                                <linearGradient id="instagram-gradient" x1="4" y1="20" x2="20" y2="4" gradientUnits="userSpaceOnUse">
                                    <stop offset="0" stop-color="#feda75" />
                                    <stop offset="0.32" stop-color="#fa7e1e" />
                                    <stop offset="0.62" stop-color="#d62976" />
                                    <stop offset="1" stop-color="#4f5bd5" />
                                </linearGradient>
                            </defs>
                            <rect x="3" y="3" width="18" height="18" rx="5" fill="url(#instagram-gradient)" />
                            <circle cx="12" cy="12" r="4" fill="none" stroke="white" stroke-width="1.8" />
                            <circle cx="17" cy="7" r="1.25" fill="white" />
                        </svg>
                        <span>اینستاگرام</span>
                    </a>

                    <a class="site-footer__social-link site-footer__social-link--bale"
                       href="https://ble.ir/nafas_shop7"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="بله فروشگاه نفس">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <rect x="3" y="3" width="18" height="18" rx="5" fill="#16a7d8" />
                            <path d="M7.6 7.2h5.4c2.25 0 3.7 1.18 3.7 3.02 0 1.02-.46 1.86-1.28 2.34.98.42 1.58 1.3 1.58 2.48 0 1.93-1.54 3.16-3.95 3.16H7.6V7.2Zm5.08 4.5c.9 0 1.42-.42 1.42-1.14 0-.7-.52-1.1-1.42-1.1h-2.46v2.24h2.46Zm.2 4.22c.98 0 1.52-.44 1.52-1.22 0-.76-.54-1.2-1.52-1.2h-2.66v2.42h2.66Z" fill="white" />
                        </svg>
                        <span>بله</span>
                    </a>
                </div>
            </section>

            <section class="site-footer__trust" aria-label="نماد اعتماد الکترونیکی">
                <h2>نماد اعتماد</h2>
                <a referrerpolicy="origin"
                   target="_blank"
                   rel="noopener noreferrer"
                   href="https://trustseal.enamad.ir/?id=6863476&Code=Zrui5tbDZP5hedYpr86ux3ygH6HnoxEB">
                    <img referrerpolicy="origin"
                         src="https://trustseal.enamad.ir/logo.aspx?id=6863476&Code=Zrui5tbDZP5hedYpr86ux3ygH6HnoxEB"
                         alt="نماد اعتماد الکترونیکی فروشگاه نفس"
                         style="cursor:pointer"
                         code="Zrui5tbDZP5hedYpr86ux3ygH6HnoxEB" />
                </a>
            </section>
        </div>
    </footer>
</div>

<div id="blazor-error-ui">
    خطایی رخ داد.
    <a href="" class="reload">بارگذاری دوباره</a>
    <a class="dismiss">×</a>
</div>
